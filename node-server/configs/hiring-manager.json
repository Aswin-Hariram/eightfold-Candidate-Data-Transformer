{
  "name": "Hiring-manager view",
  "description": "Strict missing policy + provenance for audit, keeps experience/education arrays.",
  "fields": [
    {"key": "candidate_id", "from": "candidate_id"},
    {"key": "name", "from": "full_name", "normalize": "name"},
