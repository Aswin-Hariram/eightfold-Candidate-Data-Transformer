{
  "name": "candidate-transformer",
  "version": "1.0.0",
  "description": "Multi-Source Candidate Data Transformer - Eightfold assignment",
  "main": "src/server.js",
  "bin": {
    "candidate-transform": "src/cli/index.js"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node src/server.js",
    "cli": "node src/cli/index.js",
    "demo:default": "node src/cli/index.js --inputs sample-data --config configs/default.json --out output/default.json",
    "demo:custom": "node src/cli/index.js --inputs sample-data --config configs/custom-recruiter.json --out output/custom-recruiter.json",
    "demo:summary": "node src/cli/index.js --sample --format summary",
    "demo:table": "node src/cli/index.js --sample --format table",
    "demo:conflicts": "node src/cli/index.js --sample --format conflicts",
    "test": "node test/run.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "express": "^4.19.2",
    "libphonenumber-js": "^1.11.7",
    "mammoth": "^1.12.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^2.4.5",
    "yargs": "^17.7.2"
  }
}
